# === SprachBrücke Server Konfiguration ===

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sprachbruecke?retryWrites=true&w=majority

# JWT Secret (beliebiger langer zufälliger String)
JWT_SECRET=dein_geheimer_schluessel_hier_ersetzen

# OpenAI API Key
OPENAI_API_KEY=sk-...

# DeepL API Key (kostenlos: 500K Zeichen/Monat)
DEEPL_API_KEY=dein_deepl_key:fx

# Twilio (für automatische Anrufe)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+49xxxxxxxxxx

# Cloudinary (für Dokumente speichern) - optional
CLOUDINARY_CLOUD_NAME=dein_cloud_name
CLOUDINARY_API_KEY=dein_api_key
CLOUDINARY_API_SECRET=dein_api_secret

# Frontend URL (für CORS)
CLIENT_URL=http://localhost:5173
